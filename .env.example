# Server
SERVER_PORT=8080
SERVER_MODE=debug
SERVER_HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# Frontend (Docker) - 通过 Caddy 反向代理访问后端
PUBLIC_API_URL=/api

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cms
DB_USER=cms_user
DB_PASSWORD=devpassword
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=30m

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=devpassword
REDIS_DB=0

# JWT
JWT_SECRET=dev-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# TOTP
TOTP_ENCRYPTION_KEY=dev-totp-key-change-in-production!

# RustFS (Object Storage)
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=cms-media
RUSTFS_REGION=us-east-1
RUSTFS_PORT=9000
RUSTFS_CONSOLE_PORT=9001

# Meilisearch
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=devmasterkey

# Resend (Email)
# 本地 Docker 测试: 使用 re_test (noop 模式，不发送真实邮件)
# 真实测试: 替换为 re_xxxxxxxx 开头的真实 API Key
RESEND_API_KEY=re_test
RESEND_FROM_NAME=Sky Flux CMS
RESEND_FROM_EMAIL=noreply@example.com

# Log
LOG_LEVEL=debug
